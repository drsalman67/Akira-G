<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Akira-G Settings"
        android:textColor="#39FF14"
        android:textSize="26sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="32dp"/>

    <Switch
        android:id="@+id/switch_battery_color"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Adaptive Battery Color"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:padding="12dp"
        android:theme="@style/Theme.AppCompat.DayNight"/>

    <Switch
        android:id="@+id/switch_notif_light"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Notification Lighting (Red)"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:padding="12dp"
        android:theme="@style/Theme.AppCompat.DayNight"/>

    <Switch
        android:id="@+id/switch_charge_anim"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Charging Animation"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:padding="12dp"
        android:theme="@style/Theme.AppCompat.DayNight"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginVertical="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select Default Neon Color"
        android:textColor="#AAAAAA"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button android:id="@+id/c_green" android:layout_width="35dp" android:layout_height="35dp" android:backgroundTint="#39FF14" android:layout_margin="4dp"/>
        <Button android:id="@+id/c_cyan" android:layout_width="35dp" android:layout_height="35dp" android:backgroundTint="#00FFFF" android:layout_margin="4dp"/>
        <Button android:id="@+id/c_blue" android:layout_width="35dp" android:layout_height="35dp" android:backgroundTint="#0096FF" android:layout_margin="4dp"/>
        <Button android:id="@+id/c_purple" android:layout_width="35dp" android:layout_height="35dp" android:backgroundTint="#BC13FE" android:layout_margin="4dp"/>
        <Button android:id="@+id/c_pink" android:layout_width="35dp" android:layout_height="35dp" android:backgroundTint="#FF10F0" android:layout_margin="4dp"/>
        <Button android:id="@+id/c_orange" android:layout_width="35dp" android:layout_height="35dp" android:backgroundTint="#FF5F1F" android:layout_margin="4dp"/>
        <Button android:id="@+id/c_red" android:layout_width="35dp" android:layout_height="35dp" android:backgroundTint="#FF3131" android:layout_margin="4dp"/>
    </LinearLayout>

</LinearLayout>
